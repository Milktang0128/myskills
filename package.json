{
  "name": "myskills",
  "version": "0.1.1",
  "private": true,
  "description": "AI Skill Hub — unified management of AI agent skills across Claude, Codex and other platforms",
  "author": "tangmilk1205@gmail.com",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n NEXT,ELEC -c blue,green \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:next": "next dev --port 4477",
    "dev:electron": "wait-on tcp:4477 && cross-env NODE_ENV=development tsx electron/dev.ts",
    "build": "next build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json && node electron/build-preload.mjs",
    "package": "npm run build && electron-builder --mac",
    "package:signed": "set -a && [ -f .env.local ] && . ./.env.local; set +a; npm run package",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.7.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.kanbenzhi.myskills",
    "productName": "MySkills",
    "copyright": "Copyright © 2026 Milk Tang",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "out/**",
      "package.json",
      "!node_modules/@next/**",
      "!node_modules/@img/**",
      "!node_modules/next/**",
      "!node_modules/react/**",
      "!node_modules/react-dom/**",
      "!node_modules/@radix-ui/**",
      "!node_modules/lucide-react/**",
      "!node_modules/tailwindcss/**",
      "!node_modules/typescript/**",
      "!node_modules/esbuild/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/@electron/**",
      "!node_modules/.cache/**"
    ],
    "afterSign": "scripts/notarize.cjs",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en",
      "zh_CN"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "format": "ULFO"
    }
  }
}
