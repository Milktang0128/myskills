{
  "name": "myskills",
  "version": "0.2.0-tauri.0",
  "private": true,
  "description": "AI Skill Hub — unified management of AI agent skills across Claude, Codex and other platforms",
  "author": "tangmilk1205@gmail.com",
  "scripts": {
    "dev": "tauri dev",
    "dev:tauri": "tauri dev",
    "dev:next": "next dev --port 4477",
    "dev:electron:legacy": "wait-on tcp:4477 && cross-env NODE_ENV=development tsx electron/dev.ts",
    "dev:electron": "wait-on tcp:4477 && cross-env NODE_ENV=development tsx electron/dev.ts",
    "build": "next build",
    "build:tauri": "tauri build",
    "build:tauri:mac:signed": "tauri build --config src-tauri/tauri.macos.signing.conf.json",
    "notarize:tauri:mac": "node scripts/notarize-tauri-macos.mjs",
    "check:commands": "node scripts/audit-tauri-commands.mjs",
    "check:rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "check:rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:tauri": "npm run check:commands && npm run check:rust:fmt && npm run check:rust:clippy && npm run test:rust && npm run build",
    "validate:tauri": "npm run check:tauri && npm run build:tauri",
    "smoke:tauri:launch": "node scripts/smoke-tauri-launch.mjs",
    "smoke:tauri:dmg": "node scripts/smoke-tauri-dmg.mjs",
    "smoke:tauri:fixtures": "node scripts/create-tauri-smoke-fixtures.mjs",
    "smoke:tauri:migration": "cargo test --manifest-path src-tauri/Cargo.toml migration::tests::stable_migration_drill_imports_copy_and_rolls_back_without_source_mutation -- --exact",
    "smoke:ui:workbench": "node scripts/smoke-ui-workbench.mjs",
    "build:electron:legacy": "next build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json && node electron/build-preload.mjs",
    "package:electron:legacy": "npm run build:electron:legacy && electron-builder --mac",
    "package:signed:electron:legacy": "set -a && [ -f .env.local ] && . ./.env.local; set +a; npm run package:electron:legacy",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "better-sqlite3": "^12.4.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.7.1",
    "@tauri-apps/cli": "^2.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.kanbenzhi.myskills",
    "productName": "MySkills",
    "copyright": "Copyright © 2026 Milk Tang",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "out/**",
      "package.json",
      "!node_modules/@next/**",
      "!node_modules/@img/**",
      "!node_modules/next/**",
      "!node_modules/react/**",
      "!node_modules/react-dom/**",
      "!node_modules/@radix-ui/**",
      "!node_modules/lucide-react/**",
      "!node_modules/tailwindcss/**",
      "!node_modules/typescript/**",
      "!node_modules/esbuild/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/@electron/**",
      "!node_modules/.cache/**"
    ],
    "afterSign": "scripts/notarize.cjs",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en",
      "zh_CN"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "format": "ULFO"
    }
  }
}
