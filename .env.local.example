# MySkills — Apple Developer signing & notarization credentials.
#
# Copy this file to `.env.local` (already gitignored) and fill in the values
# for YOUR Developer account. The `package:signed` npm script sources this
# automatically before invoking electron-builder.
#
# These four variables are used at two points in the build pipeline:
#   1. electron-builder signs the .app using a Developer ID Application cert
#      found in the user's Keychain (no env var needed — picks the cert by
#      matching the Team ID).
#   2. scripts/notarize.cjs (afterSign hook) submits the signed .app to
#      Apple's notary service via notarytool, authenticating with the
#      App Store Connect API key below.
#
# Get these values once and they're good until Apple rotates them (you can
# create new API keys whenever; the cert is valid for ~5 years).

# Absolute path to your App Store Connect API key (.p8 file).
# Download at: https://appstoreconnect.apple.com/access/integrations/api
# (Role = Developer is sufficient for notarization.)
# The .p8 can only be downloaded ONCE — store it somewhere safe.
APPLE_API_KEY=

# The 10-character Key ID — visible in the .p8 filename:
#   AuthKey_H23KWSSWK4.p8   →   APPLE_API_KEY_ID=H23KWSSWK4
APPLE_API_KEY_ID=

# Issuer UUID — shown on the App Store Connect → Users and Access →
# Integrations → App Store Connect API page (top of the page, above the
# keys list). Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APPLE_API_ISSUER=

# Your 10-char Team ID — from https://developer.apple.com/account
# (Membership → Team ID) or as the parenthesized suffix of your
# "Developer ID Application: <Name> (<TEAM_ID>)" cert in Keychain.
# Not strictly required by notarytool when using API key auth, but
# recorded here for reference and used by electron-builder cert lookup.
APPLE_TEAM_ID=
